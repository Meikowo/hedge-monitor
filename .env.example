# ============ 复制本文件为 .env 并填值（.env 已被 gitignore） ============

# Supabase 项目（Dashboard → Settings → API）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# MiniMax API key —— 就放在这里（本地）；GitHub 侧放 repo Secrets，同名 LLM_API_KEY
LLM_API_KEY=

# 以下为默认值，一般不用改
# LLM_BASE_URL=https://api.minimaxi.com/v1
# LLM_MODEL=MiniMax-M3
# LLM_TEMPERATURE=1.0
# LLM_MAX_TOKENS=8000
# LLM_THINKING=on
