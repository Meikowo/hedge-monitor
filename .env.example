# Supabase 项目地址，例如：https://xxxx.supabase.co
SUPABASE_URL=

# 只能放在本地 .env 或 GitHub Actions Secrets，绝对不要写进 HTML
SUPABASE_SERVICE_ROLE_KEY=

# 可选：爬取最近几天，默认 3
CRAWL_DAYS=3

# ---- LLM 抽取（scripts/extract_*.py）----
# 任意 OpenAI 兼容厂商均可；默认 MiniMax（注意国内站是 minimaxi 带 i）
LLM_API_KEY=
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M3
# 可选：LLM_TEMPERATURE=1.0 / LLM_MAX_TOKENS=4000 / LLM_THINKING=on
